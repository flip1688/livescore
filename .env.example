# HTTP
PORT=8080

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=livescore

# Redis (docker compose up -d redis)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# thscore (auth = api_key query param; ดู docs/thscore-api.md)
THSCORE_BASE_URL=https://www.thscore.info
THSCORE_API_KEY=

# Cache TTLs (Go duration syntax)
DICTIONARY_TTL=6h
LIVE_TTL=10s

# TTL auto-expiry (days) สำหรับ matches/match_events/match_stats
# (MongoDB TTL index) — ไม่มีผลกับ standings/leagues/teams/countries
# <= 0 = ปิด TTL (ไม่ลบอัตโนมัติ)
MATCH_RETENTION_DAYS=30

# TTL แยกสำหรับ match_analysis (H2H blob ~16KB/match, ใช้ไม่ได้แล้วหลังจบแมตช์)
# <= 0 = ปิด TTL
ANALYSIS_RETENTION_DAYS=7

# WebSocket origin allowlist (comma-separated; ว่าง = allow all, dev เท่านั้น)
WS_ALLOWED_ORIGINS=

# CORS origin allowlist สำหรับ REST API (comma-separated; ว่าง = ปิด CORS ทั้งหมด, "*" = allow ทุก origin)
CORS_ALLOWED_ORIGINS=

# Cloudflare R2 — logo mirroring (ทีม/ลีก, ห้าม hotlink thscore)
# ว่าง = ปิด logo mirroring, เก็บ URL ต้นทางไว้แทน (ต้องตั้งครบทั้ง 5 ตัว หรือเว้นว่างทั้งหมด)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# DNS override สำหรับโหลดโลโก้ (host:port เช่น 1.1.1.1:53)
# ตั้งเมื่อ DNS ของเครือข่ายบล็อกโดเมน CDN โลโก้ของ thscore (titan007.com) เช่น ISP ไทย
LOGO_DNS_SERVER=
